# Default runtime profile (Postgres-capable with auto fallback)
TZ=Europe/Vienna
EA_HOST_PORT=8090

# App runtime
EA_APP_NAME=ea-rewrite
EA_ROLE=api
EA_RUNTIME_MODE=dev
EA_HOST=0.0.0.0
EA_PORT=8090
EA_LOG_LEVEL=INFO
EA_STORAGE_BACKEND=auto
EA_DEFAULT_PRINCIPAL_ID=local-user
EA_API_TOKEN=

# Database
POSTGRES_DB=ea
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG@ea-db:5432/ea

# Optional 1min.AI key rotation (local .env only; keep real keys out of git)
ONEMIN_AI_API_KEY=
ONEMIN_AI_API_KEY_FALLBACK_1=
ONEMIN_AI_API_KEY_FALLBACK_2=
ONEMIN_AI_API_KEY_FALLBACK_3=
ONEMIN_AI_API_KEY_FALLBACK_4=
ONEMIN_AI_API_KEY_FALLBACK_5=
ONEMIN_AI_API_KEY_FALLBACK_6=
ONEMIN_AI_API_KEY_FALLBACK_7=
ONEMIN_AI_API_KEY_FALLBACK_8=

# Optional BrowserAct key rotation (local .env only; keep real keys out of git)
BROWSERACT_API_KEY=
BROWSERACT_API_KEY_FALLBACK_1=
BROWSERACT_API_KEY_FALLBACK_2=
BROWSERACT_API_KEY_FALLBACK_3=
BROWSERACT_CHATPLAYGROUND_URL=https://web.chatplayground.ai/

# Optional Unmixr key slots (local .env only; keep real keys out of git)
UNMIXR_API_KEY=

# Optional generic provider credentials
AI_MAGICX_API_KEY=
BROWSERLY_API_KEY=
MARKUPGO_API_KEY=
PROMPTING_SYSTEMS_API_KEY=
TEABLE_API_KEY=

# BrowserAct bootstrap architect
BROWSERACT_ARCHITECT_WORKFLOW_ID=
BROWSERACT_ARCHITECT_WORKFLOW_QUERY=browseract architect
BROWSERACT_USERNAME=
BROWSERACT_PASSWORD=

# Generic Gemini CLI adapter
EA_GEMINI_VORTEX_COMMAND=gemini
EA_GEMINI_VORTEX_MODEL=gemini-3-flash-preview
EA_GEMINI_VORTEX_TIMEOUT_SECONDS=180

# Responses API upstream coding providers
EA_RESPONSES_PROVIDER_ORDER=onemin,magixai
EA_RESPONSES_TIMEOUT_SECONDS=180
EA_RESPONSES_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/133.0.0.0 Safari/537.36
EA_RESPONSES_MAGICX_URLS=https://www.aimagicx.com/api/v1/chat/completions,https://www.aimagicx.com/api/v1/chat,https://beta.aimagicx.com/api/v1/chat/completions,https://beta.aimagicx.com/api/v1/chat
EA_RESPONSES_MAGICX_MODELS=inception/mercury-coder,mistralai/codestral-2508,x-ai/grok-code-fast-1,openai/gpt-5.1-codex-mini
EA_RESPONSES_MAX_OUTPUT_TOKENS_FAST=2048
EA_RESPONSES_MAX_OUTPUT_TOKENS_REVIEW=2048
EA_RESPONSES_MAX_OUTPUT_TOKENS_HARD=8192
EA_RESPONSES_MAX_OUTPUT_TOKENS_OVERFLOW=1536
EA_RESPONSES_ONEMIN_CHAT_URL=https://api.1min.ai/api/chat-with-ai
EA_RESPONSES_ONEMIN_CODE_URL=https://api.1min.ai/api/features
EA_RESPONSES_ONEMIN_INCLUDED_CREDITS_PER_KEY=4000000
EA_RESPONSES_ONEMIN_BONUS_CREDITS_PER_KEY=450000
EA_RESPONSES_ONEMIN_DELETED_KEY_QUARANTINE_SECONDS=86400
EA_RESPONSES_ONEMIN_CODE_MODELS=gpt-5,gpt-4o
EA_RESPONSES_ONEMIN_MODELS=gpt-5,gpt-4.1,deepseek-chat,gpt-4.1-nano
EA_RESPONSES_CHATPLAYGROUND_MODELS=
EA_RESPONSES_CHATPLAYGROUND_ROLES=
EA_RESPONSES_CHATPLAYGROUND_TIMEOUT_SECONDS=180

# Chummer6 guide runtime overrides live in /docker/fleet/.chummer6_local_policy.json
# (see /docker/fleet/.chummer6_local_policy.example.json for the shape).
