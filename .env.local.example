# Local quick-start profile (memory backend)
TZ=Europe/Vienna
EA_HOST_PORT=8090

# App runtime
EA_APP_NAME=ea-rewrite-local
EA_ROLE=api
EA_RUNTIME_MODE=dev
EA_HOST=0.0.0.0
EA_PORT=8090
EA_LOG_LEVEL=INFO
EA_STORAGE_BACKEND=memory
EA_DEFAULT_PRINCIPAL_ID=local-user
EA_API_TOKEN=

# Database (required by compose service, even when using memory backend)
POSTGRES_DB=ea
POSTGRES_USER=postgres
POSTGRES_PASSWORD=local_dev_only
DATABASE_URL=postgresql://postgres:local_dev_only@ea-db:5432/ea

# Optional 1min.AI key rotation (local .env only; keep real keys out of git)
ONEMIN_AI_API_KEY=
ONEMIN_AI_API_KEY_FALLBACK_1=
ONEMIN_AI_API_KEY_FALLBACK_2=
ONEMIN_AI_API_KEY_FALLBACK_3=
ONEMIN_AI_API_KEY_FALLBACK_4=
ONEMIN_AI_API_KEY_FALLBACK_5=
ONEMIN_AI_API_KEY_FALLBACK_6=
ONEMIN_AI_API_KEY_FALLBACK_7=
ONEMIN_AI_API_KEY_FALLBACK_8=
ONEMIN_AI_API_KEY_FALLBACK_9=
ONEMIN_AI_API_KEY_FALLBACK_10=
ONEMIN_AI_API_KEY_FALLBACK_11=
ONEMIN_AI_API_KEY_FALLBACK_12=
ONEMIN_AI_API_KEY_FALLBACK_13=
ONEMIN_AI_API_KEY_FALLBACK_14=
ONEMIN_AI_API_KEY_FALLBACK_15=
ONEMIN_AI_API_KEY_FALLBACK_16=
ONEMIN_AI_API_KEY_FALLBACK_17=
ONEMIN_AI_API_KEY_FALLBACK_18=
ONEMIN_AI_API_KEY_FALLBACK_19=
ONEMIN_AI_API_KEY_FALLBACK_20=
ONEMIN_AI_API_KEY_FALLBACK_21=
ONEMIN_AI_API_KEY_FALLBACK_22=
ONEMIN_AI_API_KEY_FALLBACK_23=
ONEMIN_AI_API_KEY_FALLBACK_24=
ONEMIN_AI_API_KEY_FALLBACK_25=
ONEMIN_AI_API_KEY_FALLBACK_26=
ONEMIN_AI_API_KEY_FALLBACK_27=
ONEMIN_AI_API_KEY_FALLBACK_28=
ONEMIN_AI_API_KEY_FALLBACK_29=
ONEMIN_AI_API_KEY_FALLBACK_30=
ONEMIN_AI_API_KEY_FALLBACK_31=
ONEMIN_AI_API_KEY_FALLBACK_32=
ONEMIN_AI_API_KEY_FALLBACK_33=

# Optional BrowserAct key rotation (local .env only; keep real keys out of git)
BROWSERACT_API_KEY=
BROWSERACT_API_KEY_FALLBACK_1=
BROWSERACT_API_KEY_FALLBACK_2=
BROWSERACT_API_KEY_FALLBACK_3=
BROWSERACT_CHATPLAYGROUND_URL=https://web.chatplayground.ai/
EA_RESPONSES_CHATPLAYGROUND_URLS=

# Optional Unmixr key slots (local .env only; keep real keys out of git)
UNMIXR_API_KEY=

# Optional generic provider credentials
AI_MAGICX_API_KEY=
BROWSERLY_API_KEY=
MARKUPGO_API_KEY=
PROMPTING_SYSTEMS_API_KEY=
TEABLE_API_KEY=
SOUNDMADESEN_API_KEY=

# BrowserAct bootstrap architect
BROWSERACT_ARCHITECT_WORKFLOW_ID=
BROWSERACT_ARCHITECT_WORKFLOW_QUERY=browseract architect
BROWSERACT_USERNAME=
BROWSERACT_PASSWORD=

# Generic Gemini CLI adapter
EA_GEMINI_VORTEX_COMMAND=gemini
EA_GEMINI_VORTEX_MODEL=gemini-3-flash-preview
EA_GEMINI_VORTEX_TIMEOUT_SECONDS=180

# Responses API upstream coding providers
EA_RESPONSES_DEFAULT_PROFILE=easy
EA_RESPONSES_PROVIDER_ORDER=magixai,onemin
EA_RESPONSES_TIMEOUT_SECONDS=180
EA_RESPONSES_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/133.0.0.0 Safari/537.36
EA_RESPONSES_MAGICX_HEALTH_CHECK=1
EA_RESPONSES_MAGICX_HEALTH_INTERVAL_SECONDS=300
EA_RESPONSES_MAGICX_HEALTH_TIMEOUT_SECONDS=5
EA_RESPONSES_MAGICX_URLS=https://www.aimagicx.com/api/v1/chat/completions,https://www.aimagicx.com/api/v1/chat,https://beta.aimagicx.com/api/v1/chat/completions,https://beta.aimagicx.com/api/v1/chat
EA_RESPONSES_MAGICX_MODELS=inception/mercury-coder,mistralai/codestral-2508,x-ai/grok-code-fast-1,openai/gpt-5.1-codex-mini
EA_RESPONSES_HARD_MAX_ACTIVE_REQUESTS=1
EA_RESPONSES_HARD_QUEUE_TIMEOUT_SECONDS=120
EA_RESPONSES_MAX_OUTPUT_TOKENS_FAST=768
EA_RESPONSES_MAX_OUTPUT_TOKENS_REVIEW=768
EA_RESPONSES_MAX_OUTPUT_TOKENS_HARD=1536
EA_RESPONSES_MAX_OUTPUT_TOKENS_OVERFLOW=512
EA_RESPONSES_ONEMIN_CHAT_URL=https://api.1min.ai/api/chat-with-ai
EA_RESPONSES_ONEMIN_CODE_URL=https://api.1min.ai/api/features
EA_RESPONSES_ONEMIN_INCLUDED_CREDITS_PER_KEY=4000000
EA_RESPONSES_ONEMIN_BONUS_CREDITS_PER_KEY=450000
EA_RESPONSES_ONEMIN_DELETED_KEY_QUARANTINE_SECONDS=86400
EA_RESPONSES_ONEMIN_ACTIVE_SLOTS=primary,fallback_1
EA_RESPONSES_ONEMIN_RESERVE_SLOTS=fallback_2,fallback_3,fallback_4,fallback_5,fallback_6,fallback_7,fallback_8,fallback_9,fallback_10,fallback_11,fallback_12,fallback_13,fallback_14,fallback_15,fallback_16,fallback_17,fallback_18,fallback_19,fallback_20,fallback_21,fallback_22,fallback_23,fallback_24,fallback_25,fallback_26,fallback_27,fallback_28,fallback_29,fallback_30,fallback_31,fallback_32,fallback_33
EA_RESPONSES_ONEMIN_MAX_REQUESTS_PER_HOUR=120
EA_RESPONSES_ONEMIN_MAX_CREDITS_PER_HOUR=80000
EA_RESPONSES_ONEMIN_MAX_CREDITS_PER_DAY=600000
EA_RESPONSES_ONEMIN_CODE_MODELS=gpt-5,gpt-4o
EA_RESPONSES_ONEMIN_MODELS=gpt-5,gpt-4.1,deepseek-chat,gpt-4.1-nano
EA_RESPONSES_CHATPLAYGROUND_MODELS=
EA_RESPONSES_CHATPLAYGROUND_ROLES=
EA_RESPONSES_CHATPLAYGROUND_TIMEOUT_SECONDS=180

# Survival lane (slow backup path over Gemini CLI + BrowserAct web helpers)
EA_SURVIVAL_ENABLED=1
EA_SURVIVAL_AUTO_ACTIVATE=0
EA_SURVIVAL_ROUTE_ORDER=gemini_vortex,gemini_web,chatplayground
EA_SURVIVAL_MAX_ACTIVE_REQUESTS=1
EA_SURVIVAL_QUEUE_TIMEOUT_SECONDS=900
EA_SURVIVAL_MAX_OUTPUT_TOKENS=768
EA_SURVIVAL_CACHE_TTL_SECONDS=86400
EA_SURVIVAL_GEMINI_WEB_MODE=thinking
EA_SURVIVAL_GEMINI_WEB_ALLOW_DEEP_THINK=0
EA_SURVIVAL_GEMINI_WEB_TIMEOUT_SECONDS=600
EA_SURVIVAL_CHATPLAYGROUND_SINGLE_ROLE=factuality
EA_SURVIVAL_REFUSE_CLIENT_TOOLS=1
EA_UI_CHALLENGE_COOLDOWN_SECONDS=1800
EA_UI_CHALLENGE_MAX_CONSECUTIVE=2
BROWSERACT_GEMINI_WEB_URL=

# Chummer6 guide runtime overrides live in /docker/fleet/.chummer6_local_policy.json
# (see /docker/fleet/.chummer6_local_policy.example.json for the shape).
