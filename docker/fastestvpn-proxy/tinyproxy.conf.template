User tinyproxy
Group tinyproxy
Port __PROXY_PORT__
Listen __PROXY_LISTEN__
Timeout 600
DefaultErrorFile "/usr/share/tinyproxy/default.html"
StatHost "tinyproxy.stats"
LogLevel Info
PidFile "/tmp/tinyproxy.pid"
MaxClients 100
StartServers 4
MinSpareServers 2
MaxSpareServers 8
DisableViaHeader Yes
ConnectPort 443
ConnectPort 563
Allow 0.0.0.0/0
